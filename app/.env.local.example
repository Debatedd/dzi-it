# Supabase — копирай този файл като ".env.local" и попълни стойностите
# от Supabase dashboard → Settings → API.
#
# И двете са ПУБЛИЧНИ (безопасни за браузъра). Тайния service_role ключ
# НЕ слагай тук и никъде в кода.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
